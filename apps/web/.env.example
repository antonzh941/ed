# =============================================================================
# .env.example — скопируй в .env и заполни реальными значениями
# Этот файл коммитится в репозиторий. НЕ добавляй сюда реальные секреты.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Для локальной разработки с docker-compose.yml: порт 5444
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5444/ai_tutor?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Для локальной разработки с docker-compose.yml: порт 6380
REDIS_URL="redis://localhost:6380"

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="СократAI ОГЭ"

# ─── Auth cookie secret ───────────────────────────────────────────────────────
# Обязательно в prod. Минимум 32 символа. Генерация: openssl rand -hex 32
AUTH_COOKIE_SECRET=""

# Ротация ключа (опционально): предыдущий секрет при смене
# AUTH_COOKIE_SECRET_PREVIOUS=""

# Время жизни сессии в днях (по умолчанию 30)
# AUTH_SESSION_TTL_DAYS=30

# ─── AI Gateway — основной провайдер (DeepSeek) ───────────────────────────────
# Получить: https://platform.deepseek.com
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Модели по ролям (опционально — есть дефолты в config.ts)
# GATEWAY_MODEL_TUTOR="deepseek-chat"
# GATEWAY_MODEL_EXPLAINER="deepseek-chat"
# GATEWAY_MODEL_GENERATOR="deepseek-reasoner"
# GATEWAY_MODEL_GRADER="deepseek-reasoner"

# ─── AI Gateway — fallback провайдер ─────────────────────────────────────────
# Включается автоматически, если DEEPSEEK_API_KEY недоступен
# GATEWAY_FALLBACK_API_KEY=""
# GATEWAY_FALLBACK_BASE_URL="https://api.openai.com/v1"
# GATEWAY_FALLBACK_MODEL_FAST="gpt-4o-mini"
# GATEWAY_FALLBACK_MODEL_CAPABLE="gpt-4o"

# ─── Langfuse (self-hosted трейсинг LLM-вызовов) ──────────────────────────────
# Документация: https://langfuse.com/docs/deployment/self-host
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_BASE_URL="http://localhost:3030"

# ─── VK ID OAuth ──────────────────────────────────────────────────────────────
# Client ID — публичный, можно оставить как есть
VK_CLIENT_ID="54572048"
# Client Secret — получить в https://id.vk.com/about/business/go
VK_CLIENT_SECRET=""
# VK_REDIRECT_URI=""  # по умолчанию: APP_BASE_URL/api/auth/oauth/callback/vk

# ─── Yandex ID OAuth (опционально) ───────────────────────────────────────────
# YANDEX_CLIENT_ID=""
# YANDEX_CLIENT_SECRET=""
# YANDEX_REDIRECT_URI=""

# ─── YooKassa (платежи) ───────────────────────────────────────────────────────
# Если не заданы — платежи отключены автоматически
# YOOKASSA_SHOP_ID=""
# YOOKASSA_SECRET_KEY=""
# YOOKASSA_RETURN_URL=""           # по умолчанию: APP_BASE_URL/pay/success
# YOOKASSA_WEBHOOK_TOKEN=""        # мин. 16 символов в prod
# YOOKASSA_WEBHOOK_BASIC_USER=""
# YOOKASSA_WEBHOOK_BASIC_PASSWORD=""
# YOOKASSA_WEBHOOK_IP_ALLOWLIST_DISABLED="false"

# ─── Telegram bot (опционально) ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=""

# ─── Dev helpers (НЕ включать в prod) ────────────────────────────────────────
# DEV_AUTH_BYPASS="1"        # обойти VK ID — ТОЛЬКО dev, никогда не prod
# DEV_AUTH_USER_KEY="dev-local-user"  # appUserKey для bypass-пользователя
# DISABLE_RATE_LIMIT="1"      # отключить rate limiting
# DISABLE_AI_RATE_LIMIT="1"  # отключить AI rate limiting
# EXPOSE_STATUS_DEBUG="1"    # подробная инфо в /api/system/status
# REQUIRE_STARTER_ENTITLEMENT_FOR_AI="1"  # требовать баланс для AI

# ─── Мониторинг ошибок (опционально) ─────────────────────────────────────────
# ERROR_REPORTING_WEBHOOK_URL=""  # webhook для prod-ошибок
